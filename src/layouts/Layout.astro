---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'M³ — Websites that get you customers',
  description = 'One engineer in Atlanta. I build websites that book jobs, plus the automations that back them. Free site review — takes two minutes.',
  path = '/',
  ogImage = '/og.svg',
  noindex = false,
} = Astro.props;

const canonical = new URL(path, Astro.site ?? 'https://m3mm.net').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0D0B14" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Michael Murillo-Martinez" />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, canonical).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' fill='%230D0B14'/%3E%3Ctext x='50%25' y='60%25' font-family='Space Grotesk,Inter,sans-serif' font-size='38' font-weight='700' text-anchor='middle' fill='%23E8ECF2'%3EM%3C/text%3E%3Ctext x='82%25' y='36%25' font-family='Space Grotesk,Inter,sans-serif' font-size='16' font-weight='700' text-anchor='middle' fill='%237DF9FF'%3E3%3C/text%3E%3C/svg%3E" />

    <!--
      Self-hosted fonts (tick-16e). Google Fonts CSS + preconnects dropped:
      Inter (400/500/600) and Space Grotesk (300–700) each ship as ONE variable
      woff2 (latin subset) served by GF for every weight, so 2 files cover all 8
      declared weights. Same-origin removes the fonts.googleapis.com CSS RTT
      (626 ms in tick-16d preview trace) and both gstatic/googleapis handshakes.
      JetBrains Mono was dropped in tick-16d; font-mono falls back to
      ui-monospace.
    -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />
    <style is:inline>
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400 600;
        font-display: swap;
        src: url('/fonts/inter-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Space Grotesk';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('/fonts/space-grotesk-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
    </style>

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: 'M³',
      url: 'https://m3mm.net/',
      description,
      areaServed: 'United States',
      founder: { '@type': 'Person', name: 'Michael Murillo-Martinez' },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Atlanta',
        addressRegion: 'GA',
        addressCountry: 'US',
      },
      // Contact via intake form. Raw email in HTML triggers Cloudflare's
      // Email Address Obfuscation, which injects cdn-cgi/scripts/…/
      // email-decode.min.js on every page and adds a same-origin RTT under
      // simulated mobile throttling. Perf/lh-mobile-baseline-tick7-… flagged
      // it in the network trace; routing contact through the intake URL
      // drops that resource without losing schema.org contact discoverability.
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'sales',
        url: 'https://m3mm.net/audit',
        availableLanguage: 'English',
      },
      knowsAbout: ['Web development', 'Automation', 'Small business websites', 'Lead generation'],
      // Structured pricing so Google can show tiered offers in search
      // results ("M³ Atlanta website cost" queries). Mirrors the four
      // Service.astro tiers verbatim; keep this in sync whenever pricing
      // changes there. Quote-only tier omits price per Google's guidance
      // that missing price is preferable to placeholder 0.
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'M³ website services',
        itemListElement: [
          {
            '@type': 'Offer',
            name: 'Basic site or cleanup',
            description: 'One-page site, landing page, or refresh — mobile-first, clear CTA, contact path wired.',
            priceSpecification: {
              '@type': 'UnitPriceSpecification',
              priceCurrency: 'USD',
              price: 500,
              minPrice: 500,
            },
            availability: 'https://schema.org/InStock',
            url: 'https://m3mm.net/#services',
          },
          {
            '@type': 'Offer',
            name: 'Business website package',
            description: 'Full custom business site with positioning, proof, service sections, and lead capture.',
            priceSpecification: {
              '@type': 'UnitPriceSpecification',
              priceCurrency: 'USD',
              price: 1000,
              minPrice: 1000,
              maxPrice: 2000,
            },
            availability: 'https://schema.org/InStock',
            url: 'https://m3mm.net/#services',
          },
          {
            '@type': 'Offer',
            name: 'SiteGuide setup + customization',
            description: 'Brand a SiteGuide starter template, configure the AI guide widget, wire launch, hand off.',
            priceSpecification: {
              '@type': 'UnitPriceSpecification',
              priceCurrency: 'USD',
              price: 500,
              minPrice: 500,
            },
            availability: 'https://schema.org/InStock',
            url: 'https://m3mm.net/#services',
          },
          {
            '@type': 'Offer',
            name: 'Premium custom company build',
            description: 'Large company site, multi-page service-line build, portal, or integration — quote-only.',
            availability: 'https://schema.org/InStock',
            url: 'https://m3mm.net/#services',
          },
        ],
      },
    })} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-clay focus:px-4 focus:py-2 focus:text-ink">Skip to content</a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />

    <!-- Photosensitivity disclaimer — informs about neon/motion + how to dim -->
    <aside class="a11y-note" role="note">
      <b>// A11Y NOTE.</b> This page uses low-intensity neon glow, a faint
      scanline overlay, and one subtle glitch cycle on the hero heading.
      It respects your system's <code>prefers-reduced-motion</code>
      automatically. If neon or motion still bothers you, hit
      <button type="button" class="inline" data-dim-inline>DIM</button>
      (button lives bottom-left) — kills every glow, animation, and
      text-shadow. Choice is remembered in your browser.
    </aside>

    <!-- Floating DIM toggle — softens the whole cyberpunk layer -->
    <button
      id="dim-toggle"
      class="dim-toggle"
      type="button"
      aria-label="Toggle dimmed / softened neon mode"
    >
      <span class="led"></span><span id="dim-label">NEON</span>
    </button>

    <!-- Sticky mobile CTA — TikTok/IG traffic converts on the button they can
         reach with their thumb. Hidden on desktop (Header nav already covers it)
         and hidden on /audit (visitor is already in the intake). Fades in
         after 260px scroll so it doesn't compete with the Hero CTA. -->
    <a
      id="sticky-cta"
      href={path === '/audit' ? '#intake' : '/audit'}
      class="sticky-cta lg:hidden"
      data-cta="sticky-mobile"
      data-section="sticky"
      data-intent="book:free-review"
      aria-label="Get a free site review"
    >
      <span>Free review</span>
      <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <script is:inline>
      // Sticky mobile CTA — reveal on scroll past the hero fold, hide near
      // the intake so it doesn't overlap the actual form. LocalStorage-persist
      // dismissed state so the visitor can hide it if they want.
      (function () {
        var el = document.getElementById('sticky-cta');
        if (!el) return;
        var intake = document.getElementById('intake');
        function tick() {
          var y = window.scrollY || window.pageYOffset;
          var shouldShow = y > 260;
          if (intake) {
            var rect = intake.getBoundingClientRect();
            var vh = window.innerHeight || document.documentElement.clientHeight;
            // Hide when the intake form is within one screen height of the top.
            if (rect.top < vh * 1.1) shouldShow = false;
          }
          el.classList.toggle('is-visible', shouldShow);
        }
        tick();
        window.addEventListener('scroll', tick, { passive: true });
        window.addEventListener('resize', tick, { passive: true });
      })();
    </script>

    <script>
      import { wireCTAs } from '@/lib/track';
      import { wireReveals } from '@/lib/reveal';
      import { wirePrefill } from '@/lib/prefill';
      import { wireLazyVideos } from '@/lib/lazyVideo';
      wireCTAs();
      wireReveals();
      wirePrefill();
      wireLazyVideos();
    </script>

    <script is:inline>
      // DIM mode — user-persistable toggle that soft-boots the neon layer
      // off. Honors prefers-reduced-motion on first load. Persists to
      // localStorage so returning visitors keep their choice.
      (function () {
        var KEY = 'm3_companysite_dim';
        var body = document.body;
        var btn = document.getElementById('dim-toggle');
        var lbl = document.getElementById('dim-label');
        if (!body || !btn || !lbl) return;
        function apply(on) {
          body.classList.toggle('dim', on);
          lbl.textContent = on ? 'DIM' : 'NEON';
        }
        var stored = null;
        try { stored = localStorage.getItem(KEY); } catch (e) {}
        var prefersReduced = window.matchMedia
          && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        apply(stored === '1' || (stored === null && prefersReduced));
        function toggle() {
          var next = !body.classList.contains('dim');
          apply(next);
          try { localStorage.setItem(KEY, next ? '1' : '0'); } catch (e) {}
        }
        btn.addEventListener('click', toggle);
        var inline = document.querySelector('[data-dim-inline]');
        if (inline) inline.addEventListener('click', toggle);
      })();
    </script>
  </body>
</html>
