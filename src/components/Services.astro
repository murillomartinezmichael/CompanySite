---
const services = [
  {
    key: 'site-that-books',
    intent: 'tier:website:starter',
    number: '01',
    title: 'Basic site or cleanup',
    for: 'New businesses, small teams, quick credibility fixes',
    from: '$500',
    body: 'A clean one-page site, landing page, or refresh that gives a business a real home base: fast, mobile-first, clear CTA, and no mystery stack.',
    bullets: [
      'One-page site or refresh with clear CTA',
      'Mobile-first, fast, and easy to read',
      'Contact path wired cleanly',
      'Starter SEO and share preview cleaned up',
    ],
    accent: 'clay',
    cta: 'Start with $100 down',
    href: '/start',
    // Owner-confirmed policy (2026-07-20): work starts after 20% down. That
    // payment is retained on cancellation; later payments remain refundable
    // until launch.
    paymentPolicy: '20% down to start. The down payment is non-refundable; all other payments are refundable before launch.',
  },
  {
    key: 'business-website',
    intent: 'tier:website:business',
    number: '02',
    title: 'Business website package',
    for: 'Small business to regional/corporate-style company sites',
    from: '$1,000-$2,000',
    body: 'A full custom business site with stronger positioning, proof, service sections, and lead capture. Built for companies that need more trust than a template can carry.',
    bullets: [
      'Homepage plus core service/proof sections',
      'Lead form, phone/email paths, and analytics events',
      'Case studies, gallery, reviews, or trust sections',
      'Clear scope cap so the price stays sane',
    ],
    accent: 'neon',
    cta: 'Get a quote',
    href: '#intake',
    paymentPolicy: '20% down to start. The down payment is non-refundable; all other payments are refundable before launch.',
  },
  {
    key: 'siteguide-setup',
    intent: 'tier:siteguide:setup',
    number: '03',
    title: 'SiteGuide setup + customization',
    for: 'Starter companies that like a template but want help launching',
    from: '$500',
    body: 'If SiteGuide is close but you want it customized, I can brand it, configure the widget, wire the launch path, and hand it off cleanly.',
    bullets: [
      'Template polish and brand adjustments',
      'Widget config and launch setup',
      'Hosting/deploy handoff',
      'Upgrade path into a custom M3 site later',
    ],
    accent: 'cyber',
    cta: 'Customize SiteGuide',
    href: '#intake',
    // No payment-policy badge — SiteGuide owns its product/payment policy.
    paymentPolicy: '',
  },
  {
    key: 'custom-builds',
    intent: 'tier:custom:scoped-project',
    number: '04',
    title: 'Premium custom company build',
    for: 'AriesOutdoorLiving / Big7Construction caliber and up',
    from: 'Quote-only over $2,000',
    body: 'Large company sites, multi-page service-line builds, portals, integrations, or anything that needs real discovery. Bigger scope gets a real quote instead of pretending it fits a starter package.',
    bullets: [
      'Large custom website or rebuild',
      'Multiple buyer lanes, service pages, or locations',
      'Forms, analytics, automations, or backend pieces',
      'Flat quote, clear scope, you own the code',
    ],
    accent: 'clay',
    cta: 'Scope a project',
    href: '#intake',
    // No badge — quote-only work sets payment terms in the contract.
    paymentPolicy: '',
  },
] as const;

const accentClasses: Record<string, { line: string; text: string; hover: string }> = {
  clay:  { line: 'via-clay/70',  text: 'text-clay',  hover: 'group-hover:text-clay-glow' },
  neon:  { line: 'via-neon/60',  text: 'text-neon',  hover: 'group-hover:text-neon' },
  cyber: { line: 'via-cyber/60', text: 'text-cyber', hover: 'group-hover:text-cyber' },
};
---

<section id="services" class="relative overflow-hidden py-24 sm:py-32">
  <!-- Character layers — pastel-Lucy poster energy, matches Hero.
       Section-level accents (spec: max one hero accent per section
       here read as "one primary anchor" — the violet triangle serves
       as the single dominant motif; halftone + glitch bar are texture,
       not accent). -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-x-0 top-1/3 mx-auto h-64 max-w-4xl bg-cyber/[0.03] blur-3xl"></div>
  </div>

  <!-- Violet triangle top-left, mirrors Hero's top-right anchor -->
  <div class="triangle-violet pointer-events-none absolute left-0 top-8 h-[340px] w-[340px] -z-10 hidden sm:block" style="transform: scaleX(-1);" aria-hidden="true"></div>

  <!-- Halftone dot swarm — cyan at bottom-right, yellow at top-right stagger -->
  <div class="halftone-dots-cyan pointer-events-none absolute -right-8 bottom-8 h-[240px] w-[300px] -z-10 hidden sm:block" aria-hidden="true"></div>
  <div class="halftone-dots pointer-events-none absolute right-16 top-24 h-[140px] w-[200px] -z-10 hidden md:block" aria-hidden="true" style="opacity: 0.55;"></div>

  <!-- Tri-stripe glitch bars framing the section -->
  <div class="glitch-bar pointer-events-none absolute inset-x-12 top-[18%] -z-10" aria-hidden="true"></div>
  <div class="glitch-bar pointer-events-none absolute inset-x-24 bottom-[14%] -z-10" aria-hidden="true" style="opacity: 0.55;"></div>

  <div class="container-page">
    <div class="reveal max-w-2xl">
      <div class="mb-6 flex items-center gap-3">
        <span class="hairline"></span>
        <p class="kicker mono">Services</p>
      </div>
      <h2 class="text-display-lg">
        <span class="highlight-yellow"><span class="fg">Pick the lane</span></span>. <span class="text-bone-dim">No mystery pricing.</span>
      </h2>
      <p class="mt-6 text-lg text-bone-dim">
        SiteGuide covers the starter-template lane. M3 covers custom business sites: $500 for simple, $1k-$2k for bounded company sites, quote-only when the scope is Aries or Big7 sized.
      </p>
    </div>

    <!-- Editorial rows -->
    <div class="mt-16 divide-y divide-ink-line/70 border-y border-ink-line/70">
      {services.map((s) => {
        const a = accentClasses[s.accent];
        return (
          <a
            href={s.href}
            class="group relative block py-10 transition-colors duration-500 hover:bg-ink-soft/40 sm:py-14"
            data-cta={`service-${s.key}`}
            data-section="services"
            data-intent={s.intent}
          >
            <!-- Accent stripe on left — always visible at 35%, brightens on hover -->
            <span class={`pointer-events-none absolute inset-y-0 left-0 w-px bg-gradient-to-b from-transparent ${a.line} to-transparent opacity-35 transition-opacity duration-500 group-hover:opacity-100`}></span>

            <div class="grid gap-8 lg:grid-cols-[auto,1fr,auto] lg:items-start lg:gap-12">
              <!-- Big number -->
              <div class={`mono text-sm ${a.text} transition-transform duration-500 group-hover:translate-x-1 sm:text-base`}>
                <span class="opacity-60">{s.number}</span>
                <span class="ml-2 opacity-40">/</span>
                <span class="ml-2 opacity-60">{services.length.toString().padStart(2, '0')}</span>
              </div>

              <!-- Content -->
              <div>
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2 sm:gap-x-4">
                  <h3 class="font-display text-2xl font-medium leading-tight text-bone sm:text-4xl lg:text-5xl">
                    {s.title}
                  </h3>
                  <span class={`mono inline-flex items-center rounded-sm border border-current/40 px-2 py-0.5 text-xs font-semibold uppercase tracking-[0.14em] ${a.text} sm:text-sm`}>
                    {s.from.toLowerCase().startsWith('quote') ? s.from : `from ${s.from}`}
                  </span>
                </div>
                <p class="mt-3 text-sm text-bone-muted">{s.for}</p>
                <p class="mt-5 max-w-2xl text-bone-dim">{s.body}</p>

                <ul class="mt-5 grid gap-2 text-sm text-bone-dim sm:grid-cols-2">
                  {s.bullets.map((b) => (
                    <li class="flex gap-2.5">
                      <span class={`mt-1 h-1.5 w-1.5 flex-none rounded-full ${a.text} bg-current opacity-60`}></span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>

                <!-- Payment-policy badge — mirrors the price-chip styling so the
                     terms read as part of the offer, not a hidden disclaimer. -->
                {s.paymentPolicy && (
                  <p class={`mono mt-5 inline-flex items-center gap-2 rounded-sm border border-current/40 px-2 py-0.5 text-xs font-semibold uppercase tracking-[0.14em] ${a.text}`}>
                    <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M8 1.5l5 2v4c0 3.2-2.1 5.6-5 7-2.9-1.4-5-3.8-5-7v-4l5-2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                      <path d="M5.75 8l1.5 1.5 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {s.paymentPolicy}
                  </p>
                )}
              </div>

              <!-- CTA arrow -->
              <div class="hidden items-center lg:flex">
                <span class={`mono text-xs uppercase tracking-[0.2em] ${a.text} ${a.hover} transition-all duration-500 group-hover:translate-x-1`}>
                  {s.cta}
                </span>
                <svg class={`ml-2 h-4 w-4 ${a.text} ${a.hover} transition-transform duration-500 group-hover:translate-x-1`} viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <p class="mt-10 max-w-2xl text-sm text-bone-muted">
      Not sure which fits? The free review below sorts it. If none of them fit,
      I'll tell you that too.
    </p>

    <!-- Downshift: budget under $500 -> SiteGuide off-the-shelf templates. Keeps low-budget visitors
         from bouncing and hands them a warm path to the M³ template store instead. -->
    <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-bone-muted">
      <span class="mono text-[11px] uppercase tracking-[0.2em] text-cyber/80">Budget under $500?</span>
      <a
        href="https://siteguide-production.up.railway.app/demos?utm_source=m3mm&utm_medium=services&utm_campaign=downshift&utm_content=services-under-500"
        class="group inline-flex items-center gap-1.5 text-bone-dim underline decoration-cyber/50 decoration-1 underline-offset-[6px] transition-colors hover:text-cyber"
        data-cta="downshift-siteguide"
        data-section="services"
        data-intent="product:siteguide"
        target="_blank"
        rel="noopener"
      >
        Grab an off-the-shelf template from SiteGuide
        <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>
