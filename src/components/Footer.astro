---
const year = new Date().getFullYear();

// Split so CF's edge email regex can't match. Hydrated to a real mailto:
// on load; without JS the link falls through to the intake page.
const EMAIL_USER = 'murillomartinezmichael';
const EMAIL_HOST = 'gmail.com';
const EMAIL_SUBJECT = 'Free site review request — m3mm.net';
const EMAIL_BODY = "Hey Mike,\n\nBusiness: \nCurrent site: \nWhat's frustrating me: \n\n— sent from m3mm.net footer";
---

<footer class="mt-24 border-t border-ink-line/60">
  <div class="container-page flex flex-col gap-6 py-10 text-sm text-bone-muted sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3">
      <span class="grid h-7 w-7 place-items-center rounded-md bg-ink-panel ring-1 ring-ink-line">
        <span class="font-display text-sm">M<sup class="text-[9px] text-clay">3</sup></span>
      </span>
      <span>© {year} M³ · Atlanta, GA</span>
    </div>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
      <a
        href="/audit#intake"
        class="transition-colors hover:text-bone"
        data-cta="footer-email"
        data-section="footer"
        data-intent="book:free-review"
        data-em-u={EMAIL_USER}
        data-em-h={EMAIL_HOST}
        data-em-sub={EMAIL_SUBJECT}
        data-em-body={EMAIL_BODY}
      >email →</a>
      <a href="#intake" class="transition-colors hover:text-bone" data-cta="footer-intake" data-section="footer" data-intent="book:free-review">Free site review →</a>
    </div>
  </div>
</footer>

<script is:inline>
  // Hydrate the footer email link to a real mailto: without leaving the
  // address in HTML source. Raw emails trigger Cloudflare's Email Address
  // Obfuscation, which injects a render-blocking cdn-cgi email-decode
  // script on every page (~200ms wasted in the LCP critical chain, per
  // perf/lh-mobile-baseline-tick10-…json → render-blocking-insight).
  (function () {
    var a = document.querySelector('a[data-em-u][data-em-h]');
    if (!a) return;
    var u = a.dataset.emU, h = a.dataset.emH;
    var addr = u + '@' + h;
    var sub = a.dataset.emSub || '', body = a.dataset.emBody || '';
    var q = (sub || body)
      ? '?subject=' + encodeURIComponent(sub) + '&body=' + encodeURIComponent(body)
      : '';
    a.href = 'mailto:' + addr + q;
    a.textContent = addr;
  })();
</script>
