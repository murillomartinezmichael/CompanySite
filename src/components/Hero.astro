---
interface Props {
  eyebrow?: string;
  ctaLabel?: string;
  ctaHref?: string;
  source?: string;
}
const {
  eyebrow = 'M³ · Atlanta, GA · est. 2023',
  ctaLabel = 'Get a free site review',
  ctaHref = '#intake',
  source = 'hero',
} = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <!-- Ambient hint (subtle two-stop cyan gradient at 6%) -->
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-[420px] -z-10">
    <div class="absolute inset-x-0 top-0 h-full bg-gradient-to-b from-clay/[0.06] via-transparent to-transparent"></div>
  </div>

  <div class="container-page relative pb-20 pt-14 sm:pt-20 lg:pb-28 lg:pt-24">
    <!-- Eyebrow row -->
    <div class="mb-10 flex flex-wrap items-center gap-x-4 gap-y-2">
      <span class="hairline"></span>
      <p class="kicker mono">{eyebrow}</p>
      <span class="ml-auto hidden items-center gap-2 font-mono text-[11px] uppercase tracking-[0.2em] text-bone-muted sm:inline-flex">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-clay opacity-70"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-clay" style="box-shadow: 0 0 6px currentColor;"></span>
        </span>
        <span>Booking · 24h reply</span>
      </span>
    </div>

    <h1 class="text-display-2xl">
      <span class="block text-bone">Websites that</span>
      <span class="highlight-yellow relative inline-block">
        <span class="fg relative z-10">get you customers.</span>
        <!-- Accent hairline underline (drawn on load, reinforces the highlight) -->
        <svg
          class="absolute -bottom-2 left-0 h-[0.14em] w-full text-clay/60 sm:-bottom-3"
          viewBox="0 0 400 6"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            d="M2 3 L398 3"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="square"
            fill="none"
            stroke-dasharray="500"
            style="animation: drawLine 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both;"
          />
        </svg>
      </span>
    </h1>

    <!-- Sub + CTA row: subhead on left, big authority stat on right (desktop) -->
    <div class="mt-12 grid gap-10 lg:grid-cols-[1.35fr,1fr] lg:items-end lg:gap-16">
      <div>
        <p class="max-w-2xl text-lg leading-relaxed text-bone-dim sm:text-xl">
          You saw the video — this closes the loop. TikTok and Instagram viewers become
          <span class="text-bone">DMs, quote requests, and phone calls</span>. Not clicks.
          Not vanity metrics. One engineer scopes it, ships it, hands it off — no agency
          middlemen, no monthly retainer.
        </p>

        <div class="mt-9 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href={ctaHref} class="btn-primary" data-cta="hero-review" data-section={source} data-intent="book:free-review">
            <span class="relative z-10 flex items-center gap-2.5">
              {ctaLabel}
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <p class="mono text-xs uppercase tracking-[0.2em] text-bone-muted">
            2 min · No sales call
          </p>
        </div>
      </div>

      <!-- Editorial stat block (right column on desktop) — real named client outcomes,
           pulled from src/content/caseStudies/*.md. No invented numbers. -->
      <div class="border-l border-ink-line pl-6 sm:pl-8 lg:border-l lg:pl-10">
        <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-clay/80">
          // Since 2023
        </div>
        <div class="mt-3 font-display text-display-lg leading-none text-bone">
          12<span class="text-clay">.</span>
        </div>
        <p class="mt-3 text-sm text-bone-dim">
          Client sites shipped, every one still live.
        </p>
        <div class="mt-5 space-y-3 border-t border-ink-line/70 pt-4">
          <p class="text-sm leading-snug text-bone-dim">
            <span class="mono text-[10px] uppercase tracking-[0.22em] text-clay/80">Aries Outdoor Living</span><br />
            Sold at handoff · first quote request 3 days after launch.
          </p>
          <p class="text-sm leading-snug text-bone-dim">
            <span class="mono text-[10px] uppercase tracking-[0.22em] text-clay/80">Big 7 Construction</span><br />
            Build + Repair lanes live at big7construction.com.
          </p>
        </div>
      </div>
    </div>

    <!-- Trust marquee -->
    <div class="relative mt-24 border-y border-ink-line/60 py-6 sm:mt-32">
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-ink to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-ink to-transparent"></div>
      <div class="flex overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]">
        <div class="flex shrink-0 animate-marquee items-center gap-x-14 pr-14 motion-reduce:animate-none">
          <span class="font-display text-2xl text-bone-dim">Aries Outdoor Living</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">Big 7 Construction</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">SiteGuide</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">AI Manual Assistant</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">CockpitCloud</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">PhotoPicker</span>
          <span class="text-clay">·</span>
        </div>
        <div aria-hidden="true" class="flex shrink-0 animate-marquee items-center gap-x-14 pr-14 motion-reduce:animate-none">
          <span class="font-display text-2xl text-bone-dim">Aries Outdoor Living</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">Big 7 Construction</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">SiteGuide</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">AI Manual Assistant</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">CockpitCloud</span>
          <span class="text-clay">·</span>
          <span class="font-display text-2xl text-bone-dim">PhotoPicker</span>
          <span class="text-clay">·</span>
        </div>
      </div>
    </div>
  </div>
</section>
