---
interface Props {
  eyebrow?: string;
  headline?: string;
  sub?: string;
  source?: string;
  defaultIntent?: string;
  mode?: 'review' | 'project';
  submitLabel?: string;
  successPath?: string;
  showStartWindow?: boolean;
}
const {
  eyebrow = 'Free site review',
  headline = 'Tell me what\'s broken. I\'ll tell you what to fix.',
  sub = 'Two minutes. No sales call. Within 24 hours you get a 5-minute recorded video teardown of your site: what\'s working, what\'s costing you customers, and whether it needs a rebuild or just a fix.',
  source = 'homepage',
  // CONVERSION_STANDARDS.md § 4 — every intake_submit must carry intent.
  // Visitors who scroll straight to the form without touching a CTA
  // (common on /audit, the TikTok bio target) would otherwise submit
  // with intent=undefined. Any [data-intent] click still overrides via
  // wirePrefill() before submit.
  defaultIntent = 'book:free-review',
  mode = 'review',
  submitLabel = 'Send my free review',
  successPath = '/thanks',
  showStartWindow = false,
} = Astro.props;
---

<section id="intake" class="relative py-24 sm:py-32">
  <!-- Ambient glow -->
  <div class="pointer-events-none absolute inset-x-0 top-16 -z-10 h-[400px]">
    <div class="absolute left-1/4 top-0 h-[300px] w-[300px] rounded-full bg-clay/[0.06] blur-3xl"></div>
  </div>

  <div class="container-page grid gap-14 lg:grid-cols-[1fr,1.15fr] lg:gap-20">
    <!-- Left rail -->
    <div class="reveal lg:sticky lg:top-24 lg:h-fit">
      <div class="mb-6 flex items-center gap-3">
        <span class="hairline"></span>
        <p class="kicker mono">{eyebrow}</p>
      </div>
      <h2 class="text-display-lg">{headline}</h2>
      <p class="mt-6 text-lg text-bone-dim">{sub}</p>

      <ol class="mt-10 space-y-5">
        <li class="flex gap-4">
          <span class="mono flex h-9 w-9 flex-none items-center justify-center rounded-full border border-clay/40 bg-clay/10 text-xs text-clay">01</span>
          <div>
            <p class="font-medium text-bone">Fill it out</p>
            <p class="mt-1 text-sm text-bone-dim">Under 2 minutes. Skip fields you don't have.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="mono flex h-9 w-9 flex-none items-center justify-center rounded-full border border-clay/40 bg-clay/10 text-xs text-clay">02</span>
          <div>
            <p class="font-medium text-bone">{mode === 'project' ? 'I confirm the scope' : 'I actually look'}</p>
            <p class="mt-1 text-sm text-bone-dim">{mode === 'project' ? 'I review the intake and confirm the build plan before work begins.' : 'Lighthouse, mobile, funnel, copy — all of it.'}</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="mono flex h-9 w-9 flex-none items-center justify-center rounded-full border border-clay/40 bg-clay/10 text-xs text-clay">03</span>
          <div>
            <p class="font-medium text-bone">{mode === 'project' ? 'We start the build' : 'Video teardown + rough scope'}</p>
            <p class="mt-1 text-sm text-bone-dim">{mode === 'project' ? 'Your $100 down payment reserves the next confirmed build window.' : 'A 5-minute recorded walkthrough, emailed within 24 hours. Plain English, no jargon.'}</p>
          </div>
        </li>
      </ol>

      <!-- Signature card -->
      <div class="mt-10 flex items-center gap-4 rounded-2xl border border-ink-line bg-ink-soft/60 p-5 backdrop-blur-sm">
        <div class="grid h-11 w-11 flex-none place-items-center overflow-hidden rounded-full bg-ink-panel ring-1 ring-ink-line">
          <img src="/mark-light.png" alt="" width="28" height="28" class="h-7 w-7 object-contain" decoding="async" />
        </div>
        <div class="text-sm">
          <p class="font-medium text-bone">Michael Murillo-Martinez</p>
          <p class="mt-0.5 text-xs text-bone-muted mono">One engineer · reviewing personally</p>
          <a
            href="https://www.tiktok.com/@m3mm_dev"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 inline-block text-xs text-clay hover:text-bone transition-colors"
            data-cta="signature-tiktok"
            data-section="intake"
          >
            @m3mm_dev on TikTok
          </a>
        </div>
      </div>
    </div>

    <!-- Form panel -->
    <form
      id="intake-form"
      class="reveal reveal-delay-1 panel relative flex flex-col gap-6 p-6 sm:p-9"
      method="POST"
      action="/api/lead"
      data-source={source}
      data-success-path={successPath}
      novalidate
    >
      <!-- Corner marks — editorial polish -->
      <span class="pointer-events-none absolute left-4 top-4 h-3 w-3 border-l border-t border-clay/50"></span>
      <span class="pointer-events-none absolute right-4 top-4 h-3 w-3 border-r border-t border-clay/50"></span>
      <span class="pointer-events-none absolute bottom-4 left-4 h-3 w-3 border-b border-l border-clay/50"></span>
      <span class="pointer-events-none absolute bottom-4 right-4 h-3 w-3 border-b border-r border-clay/50"></span>

      <input type="hidden" name="source" value={source} />
      <input type="hidden" name="intent" value={defaultIntent} />
      <!-- UTM capture — CONVERSION_STANDARDS.md § 4. Bio-link UTMs must
           travel with the lead POST so the admin email/log show which
           TikTok video sourced the lead. applyUrlPrefill() populates these
           from window.location.search on load; unset params stay empty
           and validate cleanly. -->
      <input type="hidden" name="utm_source" value="" />
      <input type="hidden" name="utm_medium" value="" />
      <input type="hidden" name="utm_campaign" value="" />
      <input type="hidden" name="utm_content" value="" />
      <input type="hidden" name="utm_term" value="" />

      <div class="grid gap-6 sm:grid-cols-2">
        <label class="flex flex-col gap-2">
          <span class="field-label"><span>Your name</span><span class="text-clay/60 mono">01</span></span>
          <input
            name="name"
            type="text"
            required
            autocomplete="name"
            class="field-input"
            placeholder="David Serrano"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="field-label"><span>Email</span><span class="text-clay/60 mono">02</span></span>
          <input
            name="email"
            type="email"
            required
            autocomplete="email"
            inputmode="email"
            class="field-input"
            placeholder="you@business.com"
          />
        </label>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <label class="flex flex-col gap-2">
          <span class="field-label"><span>Business type</span><span class="text-clay/60 mono">03</span></span>
          <input
            name="businessType"
            type="text"
            required
            class="field-input"
            placeholder="Contractor · gym · dentist"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="field-label"><span>Current site URL</span><span class="text-bone-muted mono">optional</span></span>
          <input
            name="currentUrl"
            type="url"
            autocomplete="url"
            class="field-input"
            placeholder="https://"
          />
        </label>
      </div>

      <label class="flex flex-col gap-2">
        <span class="field-label"><span>Biggest frustration</span><span class="text-clay/60 mono">04</span></span>
        <textarea
          name="frustration"
          rows="5"
          required
          class="field-input resize-none"
          placeholder="Site looks dated · doesn't rank · no one submits the form · phone doesn't ring after visits..."
        ></textarea>
        <span class="mono text-[10px] uppercase tracking-[0.18em] text-bone-muted">
          The more specific, the more useful the review.
        </span>
      </label>

      {showStartWindow && (
        <label class="flex flex-col gap-2">
          <span class="field-label"><span>Preferred start window</span><span class="text-clay/60 mono">05</span></span>
          <select name="preferredStart" required class="field-input">
            <option value="">Choose a window</option>
            <option value="Next available build week">Next available build week</option>
            <option value="Within 2 weeks">Within 2 weeks</option>
            <option value="Within 30 days">Within 30 days</option>
            <option value="No rush">No rush</option>
          </select>
          <span class="mono text-[10px] uppercase tracking-[0.18em] text-bone-muted">
            This is a preference. I confirm the actual build week before work starts.
          </span>
        </label>
      )}

      <!-- honeypot — bots will fill it, humans can't see it -->
      <label class="hidden" aria-hidden="true">
        <span>Company website (leave blank)</span>
        <input type="text" name="company_website" tabindex="-1" autocomplete="off" />
      </label>

      <div class="flex flex-col gap-4 pt-2 sm:flex-row sm:items-center sm:justify-between">
        <p class="mono text-[11px] uppercase tracking-[0.18em] text-bone-muted">
          <span class="text-clay/80">●</span> Encrypted in transit · Never sold
        </p>
        <button
          type="submit"
          class="btn-primary w-full sm:w-auto"
          data-cta="intake-submit"
          data-section="intake"
        >
          <span class="relative z-10 flex items-center gap-2.5">
            {submitLabel}
            <svg class="h-4 w-4 transition-transform" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </button>
      </div>

      <div
        id="intake-status"
        class="hidden rounded-lg border border-clay/40 bg-clay/10 px-4 py-3 text-sm text-bone"
        role="status"
        aria-live="polite"
      ></div>
    </form>
  </div>
</section>

<script>
  import { track } from '@/lib/track';
  import { isPriorPrefill } from '@/lib/prefill';

  const form = document.getElementById('intake-form') as HTMLFormElement | null;
  const status = document.getElementById('intake-status') as HTMLDivElement | null;

  if (form && status) {
    // CONVERSION_STANDARDS.md § 4 — intake_start fires once, on the first
    // field focus, so we can measure abandonment between CTA click and
    // submit. focusin bubbles, so a single `once` listener on the form
    // catches whichever field the visitor lands on first (name / email /
    // frustration textarea after a Services prefill, etc.).
    form.addEventListener('focusin', () => {
      const source = String(form.dataset.source || 'unknown');
      const intentInput = form.querySelector<HTMLInputElement>('input[name=intent]');
      const intent = intentInput?.value || undefined;
      track({
        name: 'intake_start',
        section: 'intake',
        intent,
        meta: { source },
      });
    }, { once: true });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type=submit]');
      const btnSpan = submitBtn?.querySelector<HTMLSpanElement>('span.relative');
      const originalBtnHTML = btnSpan?.innerHTML;
      const data = Object.fromEntries(new FormData(form).entries());

      // honeypot check
      if (data.company_website) {
        status.textContent = 'Sent — check your inbox.';
        status.classList.remove('hidden');
        return;
      }

      if (submitBtn && btnSpan) {
        submitBtn.disabled = true;
        btnSpan.innerHTML = '<span>Sending…</span>';
      }
      status.classList.remove('hidden', 'border-emerald-400/40', 'bg-emerald-500/10', 'border-red-400/40', 'bg-red-500/10');
      status.classList.add('border-clay/40', 'bg-clay/10');
      status.textContent = 'Sending…';

      const message = String(data.frustration || '');
      const hasPrefill = isPriorPrefill(message);
      const intent = String(data.intent || '') || undefined;
      const source = String(data.source || 'unknown');

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        track({
          name: 'intake_submit',
          section: 'intake',
          intent,
          meta: { source, has_prefill: hasPrefill, message_length: message.length },
        });
        status.textContent = 'Got it. Redirecting…';
        status.classList.remove('border-clay/40', 'bg-clay/10');
        status.classList.add('border-emerald-400/40', 'bg-emerald-500/10');
        form.reset();
        // Redirect to the real thank-you page for a stronger conversion story
        // (24h reply promise, next-step CTAs, urgency escape hatch). setTimeout
        // gives the analytics beacon a beat to flush before navigation.
        const destination = form.dataset.successPath || '/thanks';
        setTimeout(() => { window.location.href = destination; }, 450);
      } catch {
        track({
          name: 'intake_error',
          section: 'intake',
          intent,
          meta: { source, has_prefill: hasPrefill, message_length: message.length },
        });
        status.textContent = 'Something broke on send. Email murillomartinezmichael@gmail.com and I\'ll pick it up manually.';
        status.classList.remove('border-clay/40', 'bg-clay/10');
        status.classList.add('border-red-400/40', 'bg-red-500/10');
      } finally {
        if (submitBtn && btnSpan && originalBtnHTML) {
          submitBtn.disabled = false;
          btnSpan.innerHTML = originalBtnHTML;
        }
      }
    });
  }
</script>
