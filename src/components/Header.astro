---
interface Props {
  minimal?: boolean;
  path?: string;
}
const { minimal = false, path = '/' } = Astro.props;

// CONVERSION_STANDARDS.md § 1 — no dead-end CTAs. Only `/`, `/audit`,
// and the `/for/*` trade pages render <Intake>, so `#intake` on any other
// page scrolls to the top — a broken promise. Route those clicks to
// `/audit#intake` instead so the CTA actually lands the visitor in the form.
const hasIntakeOnPage = path === '/' || path === '/audit' || path.startsWith('/for/');
const intakeHref = hasIntakeOnPage ? '#intake' : '/audit#intake';
---

<header class="relative z-30">
  <div class="container-page flex items-center justify-between py-6">
    <a href="/" class="group flex items-center gap-2.5" aria-label="M³ home" data-cta="logo" data-section="header">
      <span
        class="grid h-9 w-9 place-items-center overflow-hidden bg-ink-soft ring-1 ring-ink-line transition-all group-hover:ring-clay/60"
        style="border-radius: 2px;"
      >
        <img
          src="/mark-light.png"
          alt=""
          width="28"
          height="28"
          class="h-7 w-7 object-contain"
          decoding="async"
        />
      </span>
      <span class="hidden font-mono text-xs uppercase tracking-[0.18em] text-bone-muted sm:inline">Websites that get you customers</span>
    </a>

    {!minimal && (
      <nav class="hidden items-center gap-8 text-sm text-bone-dim md:flex" aria-label="Primary">
        <a href="#proof" class="transition-colors hover:text-bone" data-cta="nav-proof" data-section="header">Work</a>
        <a href="#services" class="transition-colors hover:text-bone" data-cta="nav-services" data-section="header">Services</a>
        <a href={intakeHref} class="transition-colors hover:text-bone" data-cta="nav-intake" data-section="header" data-intent="book:free-review">Contact</a>
      </nav>
    )}

    <a
      href={intakeHref}
      class="inline-flex items-center gap-1.5 border border-clay bg-transparent px-4 py-2 text-sm font-semibold text-clay transition-all duration-150 hover:border-cyber hover:bg-cyber hover:text-ink hover:shadow-glow-clay"
      style="border-radius: 2px; letter-spacing: 0.03em;"
      data-cta="header-review"
      data-section="header"
      data-intent="book:free-review"
    >
      Free review ▸
    </a>
  </div>
</header>
